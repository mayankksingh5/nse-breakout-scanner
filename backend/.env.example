# Copy to .env and fill in. Do NOT commit your real .env.
PORT=5000

# Minimum market cap (in crore) for a stock to be scanned. Default 5000.
MIN_MARKET_CAP_CR=5000

# Optional: Telegram alerts for strong breakouts (score >= 85). Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Angel One SmartAPI (Phase 0 live-data validation) ---
# Fill these in your local .env (git-ignored) to run `npm run smartapi:check`.
# WARNING: these credentials can place trades, not just read prices. Treat them
# as sensitively as your trading password. Never commit them, never paste in chat.
SMARTAPI_API_KEY=          # API key from your SmartAPI app (smartapi.angelone.in)
SMARTAPI_CLIENT_CODE=      # your Angel One login / client ID
SMARTAPI_PIN=              # your login PIN
SMARTAPI_TOTP_SECRET=      # base32 seed behind the authenticator QR (NOT a 6-digit code)

# --- Live hub server (Phase 1: `npm run live`) ---
LIVE_HUB_PORT=8080         # port the hub HTTP/SSE server listens on
ALLOWED_ORIGIN=            # CORS allow-list, comma-separated (e.g. https://stockfinder-nse.vercel.app); blank = allow all (dev only)
DATASET_PATH=              # optional override for the snapshot path; blank = ../frontend/src/data/signals.json
